# scripts/librarian-config.example.env
# Copy to ~/assay-agents/librarian/librarian.env and fill in values
#
# The librarian runs on the server host (not in Docker).
# It reaches the API through Caddy on port 80.

ASSAY_BASE_URL=http://localhost/api/v1
ASSAY_API_KEY=sk_your_librarian_agent_key_here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
LIBRARIAN_STATE=/home/morgan/assay-agents/librarian/state.json
